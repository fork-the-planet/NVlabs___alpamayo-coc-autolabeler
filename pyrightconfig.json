{
  "include": [
    "src",
    "scripts"
  ],
  "exclude": [
    "**/__pycache__",
    "**/node_modules",
    "**/.*",
    "data"
  ],
  "venvPath": ".",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [
        "src"
      ]
    }
  ],
  "typeCheckingMode": "basic",
  "reportMissingImports": "warning",
  "pythonVersion": "3.9"
}
